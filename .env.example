# ─── Database ────────────────────────────────────────────────────────────────
# Required: PostgreSQL connection string.
# Recommended providers for Vercel:
#   • Neon (https://neon.tech) — free serverless PostgreSQL, native Vercel integration
#   • Supabase (https://supabase.com) — free tier available
#   • Vercel Postgres (https://vercel.com/docs/storage/vercel-postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Security ────────────────────────────────────────────────────────────────
# Required: Admin secret used to protect write/delete API endpoints.
# The admin dashboard (/admin) passes this header (X-Admin-Secret) for mutations.
# Generate a strong random string: openssl rand -base64 32
SESSION_SECRET=your-strong-random-secret-here

# ─── Optional ────────────────────────────────────────────────────────────────
# Node environment (Vercel sets this automatically to "production")
NODE_ENV=production

# Log level for the API server: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
